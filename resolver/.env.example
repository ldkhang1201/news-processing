KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_INPUT_TOPIC=articles
# KAFKA_AUDIO_TOPIC=audio_transcripts  # set to enable the audio_processing source
KAFKA_OUTPUT_TOPIC=events
KAFKA_OUTPUT_PARTITIONS=3
KAFKA_OUTPUT_REPLICATION_FACTOR=1
KAFKA_GROUP_ID=resolver
KAFKA_CLIENT_ID=resolver
KAFKA_ACKS=all
KAFKA_MAX_POLL_INTERVAL_MS=900000
KAFKA_SESSION_TIMEOUT_MS=45000

OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=qwen2.5:7b
OLLAMA_TIMEOUT_S=300
OLLAMA_BODY_MAX_CHARS=8000
OLLAMA_PREFER_SUMMARY_OVER=6000

NOMINATIM_ENDPOINT=https://nominatim.openstreetmap.org/search
NOMINATIM_USER_AGENT=vn-traffic-resolver/0.1 (khangl@nvidia.com)
NOMINATIM_RATE_LIMIT_S=1.1
NOMINATIM_TIMEOUT_S=10
NOMINATIM_FAILURE_TTL_DAYS=7
NOMINATIM_CACHE_FILE=./geocode_cache.json
NOMINATIM_COUNTRY_CODE=vn

LOG_LEVEL=INFO
